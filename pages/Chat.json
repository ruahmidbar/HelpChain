import React, { useState, useEffect, useRef } from "react";
import { useNavigate } from "react-router-dom";
import { createPageUrl } from "@/utils";
import { base44 } from "@/api/base44Client";
import { useQuery, useMutation, useQueryClient } from "@tanstack/react-query";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { ArrowRight, Send, MessageCircle } from "lucide-react";
import { Badge } from "@/components/ui/badge";
import { toast } from "sonner";

export default function Chat() {
  const navigate = useNavigate();
  const queryClient = useQueryClient();
  const messagesEndRef = useRef(null);
  const [selectedUser, setSelectedUser] = useState(null);
  const [messageText, setMessageText] = useState("");

  const { data: currentUser } = useQuery({
    queryKey: ['current-user'],
    queryFn: () => base44.auth.me(),
  });

  const { data: allUsers = [] } = useQuery({
    queryKey: ['all-users'],
    queryFn: () => base44.entities.User.list(),
    initialData: [],
  });

  const { data: allMessages = [] } = useQuery({
    queryKey: ['all-messages', currentUser?.id],
    queryFn: async () => {
      if (!currentUser) return [];
      const sent = await base44.entities.Message.filter({ from_user_id: currentUser.id });
      const received = await base44.entities.Message.filter({ to_user_id: currentUser.id });
      return [...sent, ...received];
    },
    enabled: !!currentUser,
    initialData: [],
  });

  const { data: messages = [] } = useQuery({
    queryKey: ['messages', currentUser?.id, selectedUser?.id],
    queryFn: async () => {
      if (!currentUser || !selectedUser) return [];
      const sent = await base44.entities.Message.filter({ 
        from_user_id: currentUser.id, 
        to_user_id: selectedUser.id 
      });
      const received = await base44.entities.Message.filter({ 
        from_user_id: selectedUser.id, 
        to_user_id: currentUser.id 
      });
      return [...sent, ...received].sort((a, b) => 
        new Date(a.created_date) - new Date(b.created_date)
      );
    },
    enabled: !!currentUser && !!selectedUser,
    initialData: [],
  });

  const sendMessageMutation = useMutation({
    mutationFn: async (data) => {
      const message = await base44.entities.Message.create(data);
      
      // שליחת מייל למקבל ההודעה
      const recipient = allUsers.find(u => u.id === data.to_user_id);
      if (recipient?.email) {
        try {
          await base44.integrations.Core.SendEmail({
            to: recipient.email,
            subject: `הודעה חדשה מ-${currentUser.first_name} ${currentUser.last_name} - HelpChain`,
            body: `
שלום ${recipient.first_name || 'תלמיד'},

קיבלת הודעה חדשה מ-${currentUser.first_name} ${currentUser.last_name}:

"${data.content}"

היכנס לאפליקציה כדי לקרוא ולהגיב:
${window.location.origin}

בברכה,
צוות HelpChain
            `
          });
        } catch (error) {
          console.error('Failed to send email notification:', error);
        }
      }
      
      return message;
    },
    onSuccess: () => {
      queryClient.invalidateQueries(['messages']);
      queryClient.invalidateQueries(['all-messages']);
      queryClient.invalidateQueries(['unread-messages']);
      setMessageText("");
    },
  });

  const markAsReadMutation = useMutation({
    mutationFn: (messageId) => base44.entities.Message.update(messageId, { is_read: true }),
    onSuccess: () => {
      queryClient.invalidateQueries(['messages']);
      queryClient.invalidateQueries(['all-messages']);
      queryClient.invalidateQueries(['unread-messages']);
    },
  });

  const markAsUnreadMutation = useMutation({
    mutationFn: (messageId) => base44.entities.Message.update(messageId, { is_read: false }),
    onSuccess: () => {
      queryClient.invalidateQueries(['messages']);
      queryClient.invalidateQueries(['all-messages']);
      queryClient.invalidateQueries(['unread-messages']);
    },
  });

  const handleSendMessage = () => {
    if (!messageText.trim() || !selectedUser) return;

    sendMessageMutation.mutate({
      from_user_id: currentUser.id,
      to_user_id: selectedUser.id,
      content: messageText,
      type: "הודעה רגילה"
    });
  };

  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);

  useEffect(() => {
    if (selectedUser && messages.length > 0) {
      messages.forEach(msg => {
        if (msg.to_user_id === currentUser?.id && !msg.is_read) {
          markAsReadMutation.mutate(msg.id);
        }
      });
    }
  }, [selectedUser, messages]);

  // רשימת כל המשתמשים האחרים (מלבד המשתמש הנוכחי)
  const otherUsers = allUsers
    .filter(u => u.id !== currentUser?.id)
    .filter(u => !u.is_blocked)
    .filter(u => u.first_name || u.full_name || u.email);
  
  const getUserUnreadCount = (userId) => {
    return allMessages.filter(m => 
      m.from_user_id === userId && 
      m.to_user_id === currentUser?.id && 
      !m.is_read
    ).length;
  };

  return (
    <div className="min-h-screen p-6 md:p-10" dir="rtl">
      <div className="max-w-6xl mx-auto">
        <div className="sticky top-0 z-20 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50 pb-4 pt-2">
          <Button
            variant="ghost"
            onClick={() => navigate(createPageUrl("Dashboard"))}
            className="bg-white shadow-md"
          >
            <ArrowRight className="w-4 h-4 ml-2" />
            חזור לדף הבית
          </Button>
        </div>

        <div className="mb-6">
          <h1 className="text-4xl font-bold bg-gradient-to-l from-blue-600 to-purple-600 bg-clip-text text-transparent mb-2">
            צ'אט
          </h1>
          <p className="text-gray-600 text-lg">שלח הודעות לתלמידים אחרים</p>
        </div>

        <div className="grid md:grid-cols-3 gap-6">
          <Card className="bg-white/90 backdrop-blur-sm shadow-xl">
            <CardHeader>
              <CardTitle>תלמידים</CardTitle>
            </CardHeader>
            <CardContent className="space-y-2 max-h-[600px] overflow-y-auto">
              {otherUsers.length === 0 ? (
                <p className="text-gray-500 text-center py-8">אין תלמידים אחרים</p>
              ) : (
                otherUsers.map((user) => (
                  <button
                    key={user.id}
                    onClick={() => setSelectedUser(user)}
                    className={`w-full text-right p-3 rounded-xl transition-colors ${
                      selectedUser?.id === user.id
                        ? 'bg-purple-100 text-purple-700'
                        : 'hover:bg-gray-100'
                    }`}
                  >
                    <p className="font-medium">
                      {user.first_name && user.last_name 
                        ? `${user.first_name} ${user.last_name}`
                        : user.full_name || user.email}
                    </p>
                    {getUserUnreadCount(user.id) > 0 && (
                      <Badge className="bg-red-500 text-white">
                        {getUserUnreadCount(user.id)}
                      </Badge>
                    )}
                  </button>
                ))
              )}
            </CardContent>
          </Card>

          <Card className="md:col-span-2 bg-white/90 backdrop-blur-sm shadow-xl">
            {!selectedUser ? (
              <CardContent className="p-12 text-center">
                <MessageCircle className="w-16 h-16 text-gray-400 mx-auto mb-4" />
                <p className="text-gray-500">בחר תלמיד כדי להתחיל שיחה</p>
              </CardContent>
            ) : (
              <>
                <CardHeader className="border-b">
                  <CardTitle>
                    שיחה עם {selectedUser.first_name} {selectedUser.last_name}
                  </CardTitle>
                </CardHeader>
                <CardContent className="p-0">
                  <div className="h-[450px] overflow-y-auto p-4 space-y-3">
                    {messages.length === 0 ? (
                      <p className="text-gray-500 text-center py-8">אין הודעות עדיין</p>
                    ) : (
                      messages.map((msg) => (
                        <div
                          key={msg.id}
                          className={`flex ${
                            msg.from_user_id === currentUser.id ? 'justify-end' : 'justify-start'
                          }`}
                        >
                          <div
                            className={`max-w-[70%] p-3 rounded-xl relative ${
                              msg.from_user_id === currentUser.id
                                ? 'bg-purple-600 text-white'
                                : msg.is_read ? 'bg-gray-100 text-gray-900' : 'bg-blue-50 text-gray-900 border-2 border-blue-300'
                            }`}
                            onContextMenu={(e) => {
                              e.preventDefault();
                              if (msg.to_user_id === currentUser.id) {
                                msg.is_read 
                                  ? markAsUnreadMutation.mutate(msg.id)
                                  : markAsReadMutation.mutate(msg.id);
                              }
                            }}
                          >
                            <p className="text-sm">{msg.content}</p>
                            <div className="flex items-center justify-between mt-1 gap-2">
                              <p className="text-xs opacity-70">
                                {new Date(msg.created_date).toLocaleTimeString('he-IL', {
                                  hour: '2-digit',
                                  minute: '2-digit'
                                })}
                              </p>
                              {msg.to_user_id === currentUser.id && !msg.is_read && (
                                <span className="text-xs font-bold">חדש</span>
                              )}
                            </div>
                          </div>
                        </div>
                      ))
                    )}
                    <div ref={messagesEndRef} />
                  </div>
                  <div className="p-4 border-t flex gap-2">
                    <Input
                      value={messageText}
                      onChange={(e) => setMessageText(e.target.value)}
                      onKeyPress={(e) => e.key === 'Enter' && handleSendMessage()}
                      placeholder="הקלד הודעה..."
                      className="flex-1"
                    />
                    <Button
                      onClick={handleSendMessage}
                      disabled={!messageText.trim()}
                    >
                      <Send className="w-4 h-4" />
                    </Button>
                  </div>
                </CardContent>
              </>
            )}
          </Card>
        </div>
      </div>
    </div>
  );
}