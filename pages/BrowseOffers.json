import React from "react";
import { useNavigate } from "react-router-dom";
import { createPageUrl } from "@/utils";
import { base44 } from "@/api/base44Client";
import { useQuery } from "@tanstack/react-query";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { ArrowRight, Calendar, Clock, MapPin } from "lucide-react";
import MessageDialog from "../components/MessageDialog";
import ConfirmMeetingDialog from "../components/ConfirmMeetingDialog";

export default function BrowseOffers() {
  const navigate = useNavigate();
  const [searchTerm, setSearchTerm] = React.useState("");
  const [filterGrade, setFilterGrade] = React.useState("all");
  const [filterSubject, setFilterSubject] = React.useState("all");

  const { data: offers = [], isLoading } = useQuery({
    queryKey: ['help-offers'],
    queryFn: () => base44.entities.HelpOffer.filter({ status: "פעיל" }, '-created_date'),
    initialData: [],
  });

  const { data: subjects = [] } = useQuery({
    queryKey: ['subjects'],
    queryFn: () => base44.entities.Subject.list(),
    initialData: [],
  });

  const { data: users = [] } = useQuery({
    queryKey: ['users'],
    queryFn: () => base44.entities.User.list(),
    initialData: [],
  });

  const { data: grades = [] } = useQuery({
    queryKey: ['grades'],
    queryFn: () => base44.entities.Grade.list(),
    initialData: [],
  });

  const getHelperName = (helperId) => {
    const user = users.find(u => u.id === helperId);
    if (!user) return "טוען...";
    return user.first_name && user.last_name 
      ? `${user.first_name} ${user.last_name}` 
      : user.full_name || user.email || "תלמיד";
  };

  const filteredOffers = offers.filter((offer) => {
    const helper = users.find(u => u.id === offer.helper_id);
    const matchesSearch = searchTerm === "" || 
      (helper && `${helper.first_name} ${helper.last_name}`.toLowerCase().includes(searchTerm.toLowerCase()));
    const matchesGrade = filterGrade === "all" || helper?.grade_id === filterGrade;
    const matchesSubject = filterSubject === "all" || offer.subjects?.includes(filterSubject);
    return matchesSearch && matchesGrade && matchesSubject;
  });

  if (isLoading) {
    return (
      <div className="min-h-screen flex items-center justify-center" dir="rtl">
        <div className="text-center">
          <div className="w-16 h-16 border-4 border-purple-200 border-t-purple-600 rounded-full animate-spin mx-auto mb-4"></div>
          <p className="text-gray-600">טוען הצעות...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen p-6 md:p-10" dir="rtl">
      <div className="max-w-6xl mx-auto">
        <div className="sticky top-0 z-20 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50 pb-4 pt-2">
          <Button
            variant="ghost"
            onClick={() => navigate(createPageUrl("Dashboard"))}
            className="bg-white shadow-md"
          >
            <ArrowRight className="w-4 h-4 ml-2" />
            חזור לדף הבית
          </Button>
        </div>

        <div className="mb-8">
          <h1 className="text-4xl font-bold bg-gradient-to-l from-green-600 to-teal-600 bg-clip-text text-transparent mb-2">
            תלמידים שמציעים עזרה
          </h1>
          <p className="text-gray-600 text-lg">בחר תלמיד וקבע איתו פגישה</p>
        </div>

        <Card className="bg-white/90 backdrop-blur-sm shadow-lg mb-6">
          <CardContent className="p-4">
            <div className="grid md:grid-cols-3 gap-4">
              <div>
                <Label className="text-sm mb-2">חיפוש לפי שם</Label>
                <Input
                  placeholder="הקלד שם תלמיד..."
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                />
              </div>
              <div>
                <Label className="text-sm mb-2">סנן לפי כיתה</Label>
                <Select value={filterGrade} onValueChange={setFilterGrade}>
                  <SelectTrigger>
                    <SelectValue placeholder="כל הכיתות" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="all">כל הכיתות</SelectItem>
                    {grades.map(grade => (
                      <SelectItem key={grade.id} value={grade.id}>{grade.name}</SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
              <div>
                <Label className="text-sm mb-2">סנן לפי מקצוע</Label>
                <Select value={filterSubject} onValueChange={setFilterSubject}>
                  <SelectTrigger>
                    <SelectValue placeholder="כל המקצועות" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="all">כל המקצועות</SelectItem>
                    {subjects.map(subject => (
                      <SelectItem key={subject.id} value={subject.id}>{subject.name}</SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
            </div>
          </CardContent>
        </Card>

        {filteredOffers.length === 0 ? (
          <Card className="bg-white/90 backdrop-blur-sm shadow-lg">
            <CardContent className="p-12 text-center">
              <p className="text-gray-500 text-lg">אין הצעות עזרה כרגע</p>
            </CardContent>
          </Card>
        ) : (
          <div className="grid md:grid-cols-2 gap-6">
            {filteredOffers.map((offer) => (
              <Card key={offer.id} className="bg-white/90 backdrop-blur-sm shadow-lg hover:shadow-xl transition-all duration-300">
                <CardHeader>
                  <CardTitle className="text-xl flex items-center justify-between">
                    <span>{getHelperName(offer.helper_id)}</span>
                    <Badge className="bg-green-100 text-green-800 border-0">
                      מציע עזרה
                    </Badge>
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-4">
                  <div>
                    <p className="text-sm text-gray-600 mb-2">תחומים:</p>
                    <div className="flex flex-wrap gap-2">
                      {offer.subjects?.map((subjectId, idx) => (
                        <Badge key={idx} variant="outline" className="border-purple-300">
                          {subjects.find(s => s.id === subjectId)?.name}
                        </Badge>
                      ))}
                    </div>
                  </div>

                  {offer.study_material && (
                    <div>
                      <p className="text-sm text-gray-600 mb-1">חומר לימוד:</p>
                      <p className="text-sm text-gray-700 bg-gray-50 p-2 rounded">{offer.study_material}</p>
                    </div>
                  )}

                  <div className="space-y-2 text-sm text-gray-600">
                    <div>
                      <p className="font-medium mb-1">טווח תאריכים:</p>
                      <div className="flex items-center gap-2">
                        <Calendar className="w-4 h-4" />
                        <span>
                          {new Date(offer.start_date).toLocaleDateString('he-IL')} - {new Date(offer.end_date).toLocaleDateString('he-IL')}
                        </span>
                      </div>
                    </div>
                    <div className="flex items-center gap-2">
                      <Clock className="w-4 h-4" />
                      <span>משך שיעור: {offer.lesson_duration} דקות</span>
                    </div>
                    <div className="flex items-center gap-2">
                      <MapPin className="w-4 h-4" />
                      <span>מקום: {offer.custom_place || offer.meeting_place}</span>
                    </div>
                  </div>

                  {offer.available_hours && offer.available_hours.length > 0 && (
                    <div>
                      <p className="text-sm text-gray-600 mb-1">ימים זמינים:</p>
                      <div className="flex flex-wrap gap-2">
                        {offer.available_hours.map((hour, idx) => (
                          <Badge key={idx} variant="outline" className="text-xs">
                            {hour.day === 'sunday' ? 'ראשון' : hour.day === 'monday' ? 'שני' : hour.day === 'tuesday' ? 'שלישי' : hour.day === 'wednesday' ? 'רביעי' : hour.day === 'thursday' ? 'חמישי' : 'שישי'} {hour.start_time}-{hour.end_time}
                          </Badge>
                        ))}
                      </div>
                    </div>
                  )}
                  <div className="grid grid-cols-2 gap-2">
                    <MessageDialog 
                      targetUserId={offer.helper_id}
                      targetUserName={getHelperName(offer.helper_id)}
                    />
                    <ConfirmMeetingDialog
                      targetUserId={offer.helper_id}
                      targetUserName={getHelperName(offer.helper_id)}
                      requestData={offer}
                      subjects={subjects}
                    />
                  </div>
                </CardContent>
              </Card>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}